<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme for the app. Uses the framework-level Material theme so we
         don't have to depend on com.google.android.material; the actual chrome
         is drawn entirely in Compose via LocalPalette, so this resource theme
         only needs to strip the default ActionBar and let the Compose layer
         draw to the edges. -->
    <style name="Theme.Notepad3" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
